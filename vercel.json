{
    "version": 2,
    "builds": [
        {
            "src": "src/main.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/main.ts"
        }
    ],
    "crons": [
        {
            "path": "/cron/monthlySummary",
            "schedule": "0 0 1 * *"
        }
    ]
}